# Environment Configuration for Surveillance Camera System

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true

# Frontend Configuration
FRONTEND_PORT=5173

# Authentication Settings
OTP_VALIDITY_SECONDS=600
MAX_OTP_ATTEMPTS=3
OTP_LENGTH=6

# SMS/OTP Service (for production)
# Uncomment and fill these to enable Twilio SMS OTP
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Email Service (future use)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SENDER_EMAIL=your_email@gmail.com
# SENDER_PASSWORD=your_app_password

# Admin Configuration
ADMIN_PHONE_NUMBER=+1234567890
ADMIN_EMAIL=admin@surveillance.local

# Security (for production)
# JWT_SECRET_KEY=your_super_secret_key_here
# JWT_ALGORITHM=HS256
# JWT_EXPIRY_HOURS=24

# Database Configuration (when migrating from in-memory)
# DATABASE_URL=postgresql://user:password@localhost:5432/surveillance_db
# or
# DATABASE_URL=mongodb://localhost:27017/surveillance_db

# CORS Settings
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
